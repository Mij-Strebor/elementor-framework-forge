<?xml version="1.0"?>
<ruleset name="AFF">
    <description>PHP CodeSniffer rules for Atomic Framework Forge for Elementor</description>

    <!-- Files and directories to check -->
    <file>.</file>

    <!-- Exclusions -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/languages/*</exclude-pattern>
    <exclude-pattern>*.min.js</exclude-pattern>
    <exclude-pattern>*.min.css</exclude-pattern>

    <!-- Formatting -->
    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg value="sp"/>
    <arg name="extensions" value="php"/>

    <!-- WordPress Coding Standards -->
    <rule ref="WordPress">
        <!-- Allow short array syntax -->
        <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
    </rule>

    <!-- Enforce the AFF text domain -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="atomic-framework-forge-for-elementor"/>
            </property>
        </properties>
    </rule>

    <!-- PHP version compatibility: minimum 7.4 -->
    <config name="minimum_supported_wp_version" value="5.8"/>
    <config name="testVersion" value="7.4-"/>
</ruleset>
